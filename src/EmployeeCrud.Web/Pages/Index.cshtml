@page
@model IndexModel
@{
    ViewData["Title"] = "Employees";
    var formTitle = Model.IsEditing ? "Edit employee" : "Add employee";
    var submitText = Model.IsEditing ? "Save changes" : "Add employee";
}

<div class="employee-header">
    <div>
        <h1>Employees</h1>
        <p class="text-muted mb-0">@Model.Employees.Count records</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Index">New employee</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success alert-dismissible fade show js-status-message" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <section class="workspace-panel">
            <h2 class="h5 mb-3">@formTitle</h2>

            <form method="post" asp-page-handler="Save" class="employee-form">
                <input type="hidden" asp-for="EmployeeId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-sm-6">
                        <label asp-for="Input.FirstName" class="form-label"></label>
                        <input asp-for="Input.FirstName" class="form-control" autocomplete="given-name" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="Input.LastName" class="form-label"></label>
                        <input asp-for="Input.LastName" class="form-control" autocomplete="family-name" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.JobTitle" class="form-label"></label>
                        <input asp-for="Input.JobTitle" class="form-control" />
                        <span asp-validation-for="Input.JobTitle" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.Department" class="form-label"></label>
                        <input asp-for="Input.Department" class="form-control" />
                        <span asp-validation-for="Input.Department" class="text-danger"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="Input.HireDate" class="form-label"></label>
                        <input asp-for="Input.HireDate" class="form-control" type="date" />
                        <span asp-validation-for="Input.HireDate" class="text-danger"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="Input.Salary" class="form-label"></label>
                        <input asp-for="Input.Salary" class="form-control" type="number" step="0.01" min="0.01" />
                        <span asp-validation-for="Input.Salary" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">@submitText</button>
                    @if (Model.IsEditing)
                    {
                        <a class="btn btn-outline-secondary" asp-page="/Index">Cancel</a>
                    }
                </div>
            </form>
        </section>

        @if (Model.SelectedEmployee is not null)
        {
            <section class="workspace-panel mt-4">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h2 class="h5 mb-1">@Model.SelectedEmployee.FullName</h2>
                        <p class="text-muted mb-0">@Model.SelectedEmployee.JobTitle</p>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" asp-page="/Index" asp-route-editId="@Model.SelectedEmployee.Id">Edit</a>
                </div>

                <dl class="employee-details mt-3 mb-0">
                    <dt>Email</dt>
                    <dd><a href="mailto:@Model.SelectedEmployee.Email">@Model.SelectedEmployee.Email</a></dd>
                    <dt>Department</dt>
                    <dd>@Model.SelectedEmployee.Department</dd>
                    <dt>Hire date</dt>
                    <dd>@Model.SelectedEmployee.HireDate.ToString("yyyy-MM-dd")</dd>
                    <dt>Salary</dt>
                    <dd>@Model.SelectedEmployee.Salary.ToString("C0")</dd>
                </dl>
            </section>
        }
    </div>

    <div class="col-lg-8">
        <section class="workspace-panel">
            <div class="table-responsive">
                <table class="table table-hover align-middle employee-table">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Department</th>
                            <th scope="col">Job title</th>
                            <th scope="col">Hire date</th>
                            <th scope="col" class="text-end">Salary</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model.Employees)
                        {
                            <tr class="@(Model.SelectedEmployee?.Id == employee.Id ? "table-primary" : string.Empty)">
                                <td>
                                    <strong>@employee.FullName</strong>
                                    <div class="text-muted small">@employee.Email</div>
                                </td>
                                <td>@employee.Department</td>
                                <td>@employee.JobTitle</td>
                                <td>@employee.HireDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@employee.Salary.ToString("C0")</td>
                                <td class="text-end">
                                    <div class="employee-actions">
                                        <a class="btn btn-sm btn-outline-secondary" asp-page="/Index" asp-route-viewId="@employee.Id">View</a>
                                        <a class="btn btn-sm btn-outline-primary" asp-page="/Index" asp-route-editId="@employee.Id">Edit</a>
                                        <form method="post"
                                              asp-page-handler="Delete"
                                              asp-route-id="@employee.Id"
                                              class="d-inline js-delete-employee"
                                              data-employee-name="@employee.FullName">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/employees.js" asp-append-version="true"></script>
}
